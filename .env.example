# ── Auth ───────────────────────────────────────────────────────────────
# Long random string used to sign session JWTs (HS256). Cookie is host-only
# (NOT a .rayanemelzi.dev cookie — that would leak to all your other projects).
# Auto Quran shares accounts by connecting to the SAME database below.
AUTH_JWT_SECRET=generate-a-long-random-secret

# ── Database (Postgres) ────────────────────────────────────────────────
# Start it with: docker compose up -d
DATABASE_URL=postgres://chromaquran:chromaquran@localhost:5432/chromaquran

# ── Instagram share (reuses Auto Quran's post_to_instagram.py) ─────────────
# Defaults assume Auto Quran sits at ../../Auto Quran relative to this app.
# AUTOQURAN_DIR=/srv/auto-quran
# AUTOQURAN_PYTHON=/srv/auto-quran/.venv/bin/python

# ── Rendering ──────────────────────────────────────────────────────────
# How many videos may render at once (keep low on a single box).
# CQ_RENDER_CONCURRENCY=1
